rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Each signed-in user has exactly one tracker document, keyed by their
    // own uid. They can only read or write the document that matches their
    // own uid — nobody can see or touch anyone else's data.
    match /trackers/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
